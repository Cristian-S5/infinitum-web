# Estas son las variables de entorno que debes configurar en el panel de Vercel
# Settings -> Environment Variables

# Datos de tu servidor de correo (SMTP)
SMTP_HOST=smtp.tuservidor.com
SMTP_PORT=465
SMTP_USER=no-reply@infinitum.uy
SMTP_PASS=tu_contraseña_super_secreta

# Correo donde quieres recibir los mensajes (puede ser el mismo u otro)
CONTACT_EMAIL=comercial@infinitum.uy
